{
  "name": "wedding",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env.localstack -- next dev -p 3022",
    "localstack:up": "docker compose up -d localstack",
    "localstack:down": "docker compose down",
    "localstack:bootstrap": "bash scripts/localstack/bootstrap.sh",
    "localstack:process": "dotenv -e .env.localstack -- node scripts/localstack/process-photos.mjs",
    "localstack:import": "dotenv -e .env.localstack -- node scripts/localstack/import-photos.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.1065.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1058.0",
    "@aws-sdk/client-dynamodb": "^3.1083.0",
    "@aws-sdk/client-rekognition": "^3.1058.0",
    "@aws-sdk/client-s3": "^3.1058.0",
    "@aws-sdk/lib-dynamodb": "^3.1083.0",
    "@aws-sdk/s3-request-presigner": "^3.1058.0",
    "@emotion/react": "^11.13.5",
    "@mantine/core": "^7.15.2",
    "@mantine/form": "^8.2.7",
    "@mantine/hooks": "^7.15.2",
    "@tabler/icons-react": "^3.26.0",
    "jose": "^6.2.3",
    "next": "15.5.18",
    "posthog-js": "^1.310.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-photo-album": "^3.6.0",
    "sharp": "^0.34.5",
    "yet-another-react-lightbox": "^3.32.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/eslintrc": "^3.2.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "autoprefixer": "^10.4.21",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.1.3",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "pg": "^8.21.0",
    "postcss": "^8.5.10",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "qs": "^6.14.1",
    "preact": "^10.28.2"
  }
}
